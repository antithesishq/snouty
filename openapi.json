{
  "openapi": "3.1.0",
  "info": {
    "title": "Antithesis API",
    "version": "1.0.0",
    "description": "The Antithesis API enables programmatic access to the Antithesis autonomous testing environments. List runs, inspect run details and retrieve logs.",
    "contact": {
      "name": "Antithesis Team",
      "url": "https://www.antithesis.com",
      "email": "support@antithesis.com"
    }
  },
  "servers": [
    {
      "url": "https://{account}.antithesis.com",
      "description": "Production",
      "variables": {
        "account": {
          "description": "Your organization's tenant name.",
          "default": "demo"
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Runs",
      "description": "Operations on test runs"
    },
    {
      "name": "Launch",
      "description": "Launch test runs and debugging sessions"
    }
  ],
  "paths": {
    "/api/{version}/runs": {
      "parameters": [
        {
          "$ref": "#/components/parameters/Version"
        }
      ],
      "get": {
        "operationId": "listRuns",
        "summary": "List all runs",
        "description": "Returns a paginated list of test runs for your organization. Results are ordered by creation time, newest first.",
        "tags": [
          "Runs"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return. Server-capped at 100.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Cursor for pagination. Pass the `next_cursor` value from a previous response to fetch the next page.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter runs by status.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "running",
                "completed",
                "failed"
              ]
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only return runs created after this timestamp (ISO 8601).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only return runs created before this timestamp (ISO 8601).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "launcher",
            "in": "query",
            "description": "Filter by the launcher that kicked off the run.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of runs.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run_List_Response"
                },
                "example": {
                  "data": [
                    {
                      "run_id": "YcYh0bux4F0rsV96Xq3XqAhv",
                      "status": "completed",
                      "type": "test",
                      "created_at": "2025-03-20T02:00:00Z",
                      "started_at": "2025-03-20T02:01:12Z",
                      "completed_at": "2025-03-20T02:31:45Z",
                      "launcher": "Payments Nightly"
                    },
                    {
                      "run_id": "b7f3a1e9d04847a1b2c3d4e5f6a7b8c9",
                      "status": "completed",
                      "type": "mvd",
                      "created_at": "2025-03-19T14:00:00Z",
                      "started_at": "2025-03-19T14:00:32Z",
                      "completed_at": "2025-03-19T14:45:10Z",
                      "launcher": "Debug Runner"
                    }
                  ],
                  "next_cursor": "2025-03-19T14:00:00Z"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/{version}/runs/{run_id}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/Version"
        }
      ],
      "get": {
        "operationId": "getRun",
        "summary": "Get run details",
        "description": "Returns the full details of a single test run, including results.",
        "tags": [
          "Runs"
        ],
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "description": "Unique identifier of the run to retrieve.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full details of the requested run.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Run_Detail"
                },
                "examples": {
                  "test_run": {
                    "summary": "A completed test run",
                    "value": {
                      "run_id": "YcYh0bux4F0rsV96Xq3XqAhv",
                      "status": "completed",
                      "type": "test",
                      "created_at": "2025-03-20T02:00:00Z",
                      "started_at": "2025-03-20T02:01:12Z",
                      "completed_at": "2025-03-20T02:31:45Z",
                      "launcher": "Payments Nightly",
                      "session_id": "1d66e9a01d7d9c892038bc100232da6b-50-1",
                      "links": {
                        "triage_report": "https://demo.antithesis.com/reports/YcYh0bux4F0rsV96Xq3XqAhv"
                      },
                      "results": {
                        "properties": [
                          {
                            "name": "No deadlocks under concurrent load",
                            "status": "failed",
                            "passed_count": 0,
                            "failed_count": 3,
                            "examples": [
                              {
                                "moment": {
                                  "input-hash": "6122721973385124456",
                                  "vtime": "70.59983575553633"
                                },
                                "message": "W0310 01:49:27.810287       1 control.go:161] Error getting value from vault...",
                                "source": {
                                  "container": "control",
                                  "name": "service_control",
                                  "pid": 1,
                                  "stream": "info"
                                }
                              }
                            ],
                            "counterexamples": [],
                            "child_properties": []
                          },
                          {
                            "name": "All transactions are eventually committed or rolled back",
                            "status": "passed",
                            "passed_count": 1200,
                            "failed_count": 0,
                            "examples": [],
                            "counterexamples": [],
                            "child_properties": []
                          }
                        ]
                      }
                    }
                  },
                  "mvd_run": {
                    "summary": "A completed multiverse debugging session",
                    "value": {
                      "run_id": "b7f3a1e9d04847a1b2c3d4e5f6a7b8c9",
                      "status": "completed",
                      "type": "mvd",
                      "created_at": "2025-03-21T14:00:00Z",
                      "started_at": "2025-03-21T14:00:32Z",
                      "completed_at": "2025-03-21T14:45:10Z",
                      "launcher": "Debug Runner",
                      "session_id": "a3b8c2d4e5f6a7b8c9d0e1f2a3b4c5d6-50-1",
                      "links": {
                        "triage_report": "https://demo.antithesis.com/reports/b7f3a1e9d04847a1b2c3d4e5f6a7b8c9"
                      },
                      "results": {
                        "target_bug_id": "BUG-4821",
                        "reproduced": true,
                        "root_cause_candidates": 2
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/{version}/launch/{launcher_name}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/Version"
        }
      ],
      "post": {
        "operationId": "launchTest",
        "summary": "Launch a test",
        "description": "Kicks off a test using the specified launcher (e.g. `basic_test` or `basic_k8s_test`). Fetches the relevant container images specified in configuration files and in `antithesis.images`, builds the test environment, and runs the test for the duration set in `antithesis.duration`. Returns an HTTP status code indicating whether the test was successfully started (not the test result itself).",
        "tags": [
          "Launch"
        ],
        "security": [
          {
            "BasicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "launcher_name",
            "in": "path",
            "description": "Name of the launcher to use. Use `basic_test` for Docker Compose orchestration or `basic_k8s_test` for Kubernetes orchestration.",
            "required": true,
            "schema": {
              "type": "string",
              "examples": [
                "basic_test",
                "basic_k8s_test"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Launch_Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Test successfully launched.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Launch_Response"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Version": {
        "name": "version",
        "in": "path",
        "description": "API version identifier.",
        "required": true,
        "schema": {
          "type": "string",
          "default": "v1",
          "examples": [
            "v1"
          ]
        }
      }
    },
    "schemas": {
      "Error_Response": {
        "type": "object",
        "description": "Standard error envelope returned by all error responses.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string",
            "description": "A machine-readable error code (e.g. `bad_request`, `unauthorized`, `not_found`, `rate_limit_exceeded`, `internal_error`).",
            "examples": [
              "bad_request"
            ]
          },
          "message": {
            "type": "string",
            "description": "A human-readable explanation of what went wrong.",
            "examples": [
              "limit must be between 1 and 100"
            ]
          }
        }
      },
      "Run_List_Response": {
        "type": "object",
        "description": "A page of test run summaries returned by the list endpoint. Use `next_cursor` to iterate through all available results.",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Run_Summary"
            }
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque pagination cursor. Pass as the `after` query parameter to fetch the next page. Null if no more pages."
          }
        }
      },
      "Run_Summary": {
        "type": "object",
        "required": [
          "run_id",
          "status",
          "created_at",
          "launcher"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "description": "Unique identifier for the run.",
            "examples": [
              "YcYh0bux4F0rsV96Xq3XqAhv"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/Run_Status"
          },
          "type": {
            "$ref": "#/components/schemas/Run_Type"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          },
          "creator": {
            "$ref": "#/components/schemas/Creator_info"
          },
          "launcher": {
            "type": "string",
            "description": "The name of the launcher that kicked off this run.",
            "examples": [
              "Payments Nightly"
            ]
          },
          "parameters": {
            "$ref": "#/components/schemas/Params"
          },
          "links": {
            "$ref": "#/components/schemas/Run_Links"
          }
        },
        "additionalProperties": true
      },
      "Run_Detail": {
        "description": "Full details of a test run. Extends Run_Summary with session information, results, and environment metadata.",
        "allOf": [
          {
            "$ref": "#/components/schemas/Run_Summary"
          },
          {
            "type": "object",
            "required": [
              "session_id"
            ],
            "properties": {
              "session_id": {
                "type": "string",
                "description": "Unique identifier for the test session. Used to correlate logs, events, and search queries back to this specific execution.",
                "examples": [
                  "1d66e9a01d7d9c892038bc100232da6b-50-1"
                ]
              },
              "results": {
                "type": "object",
                "additionalProperties": true,
                "description": "Aggregate test results for a completed run. Structure varies by run type."
              },
              "environment": {
                "$ref": "#/components/schemas/Run_Environment"
              }
            }
          }
        ]
      },
      "Launch_Response": {
        "type": "object",
        "description": "Response returned when a test is successfully launched.",
        "required": [
          "run_id"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "description": "Unique identifier for the launched run.",
            "examples": [
              "59484bec2cf242c3aeee5454c3de0e95-50-1"
            ]
          }
        }
      },
      "Launch_Request": {
        "type": "object",
        "description": "Request body for launching a test.",
        "required": [
          "params"
        ],
        "properties": {
          "params": {
            "$ref": "#/components/schemas/Params"
          }
        }
      },
      "Params": {
        "type": "object",
        "description": "Key-value pairs of run parameters. Used both when launching a test and when inspecting a run's configuration. All properties are optional.",
        "properties": {
          "antithesis.config_image": {
            "type": "string",
            "description": "The image version of your config image. Should be a single image version formatted as `image_name:tag`.",
            "examples": [
              "my-config:latest"
            ]
          },
          "antithesis.description": {
            "type": "string",
            "description": "A description of the test run. Appears in report headers and any emails triggered by the run.",
            "examples": [
              "basic_test on main"
            ]
          },
          "antithesis.duration": {
            "type": "string",
            "description": "Desired duration of the test run in minutes.",
            "examples": [
              "30"
            ]
          },
          "antithesis.images": {
            "type": "string",
            "description": "A semicolon-delimited list of container image versions needed in the testing environment. Each entry in the format `[REGISTRY/]NAME(:TAG|@DIGEST)`. Images specified by digest will be tagged as `latest` within the Antithesis environment.",
            "examples": [
              "registry/container_1:tag1; registry/container_2:latest"
            ]
          },
          "antithesis.is_ephemeral": {
            "type": "string",
            "description": "Whether the run's results should be excluded from historic reports. Set to `\"true\"` for one-off exploratory runs. Defaults to `\"false\"`.",
            "enum": [
              "true",
              "false"
            ],
            "default": "false"
          },
          "antithesis.report.recipients": {
            "type": "string",
            "description": "A semicolon-delimited list of email addresses to receive the triage report link. If not specified, emails are sent to the default users configured for the endpoint.",
            "examples": [
              "user1@example.com; user2@example.com"
            ]
          },
          "antithesis.source": {
            "type": "string",
            "description": "An identifier used to separate property history in reports. Each property's history is generated from all previous runs sharing the same source value. Useful for tracking test history per branch.",
            "examples": [
              "main",
              "feature/payments-v2"
            ]
          }
        },
        "additionalProperties": {
          "type": "string",
          "description": "Additional parameters including tooling integration parameters (e.g. `antithesis.integrations.<type>.callback_url`, `antithesis.integrations.<type>.token` where type is `github`, `discord`, or `slack`)."
        }
      },
      "Run_Status": {
        "type": "string",
        "enum": [
          "pending",
          "running",
          "completed",
          "failed"
        ],
        "description": "Current lifecycle status of a run. Transitions follow the order: `pending` → `running` → `completed` or `failed`."
      },
      "Run_Environment": {
        "type": "object",
        "description": "Environment details for the test run, including the Antithesis platform version and the full set of container images that were deployed.",
        "properties": {
          "antithesis_version": {
            "type": "string",
            "description": "Version of the Antithesis platform used for this run.",
            "examples": [
              "v49-1"
            ]
          },
          "images": {
            "type": "array",
            "description": "Container images deployed in this run.",
            "items": {
              "$ref": "#/components/schemas/Container_Image"
            }
          }
        }
      },
      "Container_Image": {
        "type": "object",
        "description": "A container image used in the test environment.",
        "required": [
          "name",
          "image"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Logical name of the service or component.",
            "examples": [
              "payments-service",
              "driver"
            ]
          },
          "image": {
            "type": "string",
            "description": "Full image reference including registry, repository, and tag.",
            "examples": [
              "registry.example.com/payments:main-abc1234"
            ]
          },
          "digest": {
            "type": "string",
            "description": "Content-addressable image digest.",
            "examples": [
              "sha256:deadbeef..."
            ]
          }
        }
      },
      "Run_Type": {
        "type": "string",
        "enum": [
          "test",
          "mvd",
          "other"
        ],
        "description": "The type of run. `test` is a standard test run, `mvd` is a multiverse debugging session, `other` covers any additional run types."
      },
      "Creator_info": {
        "type": "object",
        "description": "Information about who or what created this run. Distinguishes between CI-triggered runs, manual user-initiated runs, and agent-driven runs.",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the creator.",
            "examples": [
              "demo"
            ]
          },
          "type": {
            "type": "string",
            "description": "The type of creator (e.g. \"ci\", \"user\", \"agent\").",
            "examples": [
              "ci"
            ]
          }
        },
        "additionalProperties": true
      },
      "Run_Links": {
        "type": "object",
        "description": "Relevant links for this run, providing direct access to the triage report.",
        "properties": {
          "triage_report": {
            "type": "string",
            "format": "uri",
            "description": "URL to the triage report for this run."
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request — likely missing or invalid parameters.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error_Response"
            },
            "example": {
              "error": "bad_request",
              "message": "limit must be between 1 and 100"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized — invalid or missing authentication credentials.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error_Response"
            },
            "example": {
              "error": "unauthorized",
              "message": "Invalid or expired bearer token."
            }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error_Response"
            },
            "example": {
              "error": "not_found",
              "message": "Run not found: YcYh0bux4F0rsV96Xq3XqAhv"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded. Check standard rate-limit headers (Retry-After, X-RateLimit-Remaining, etc.) and back off.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error_Response"
            },
            "example": {
              "error": "rate_limit_exceeded",
              "message": "Too many requests. Retry after 30 seconds."
            }
          }
        }
      },
      "InternalError": {
        "description": "Unknown internal server error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error_Response"
            },
            "example": {
              "error": "internal_error",
              "message": "An unexpected error occurred. Please try again later."
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth2 bearer token obtained via the `snouty login` CLI flow. Pass the token in the Authorization header as `Authorization: Bearer <token>`."
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic auth machine credentials for your tenant. Used for webhook/launch endpoints."
      }
    }
  }
}
